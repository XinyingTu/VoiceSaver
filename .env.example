# VoiceSaver backend environment variables.
# Copy to .env and fill in only what you need. Nothing here is required for the
# local, no-keys simulated demo.

# --- Document intake (Beat 1): REAL one-shot vision call ---
# Required for POST /api/intake/vision to actually extract from an uploaded image.
OPENAI_API_KEY=
VISION_MODEL=gpt-4o

# --- Live voice (Beat 2): ElevenLabs Agents Platform ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# --- Real outbound dialing (Beat 2): Twilio / SIP (documented stub) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Market discovery (Beat 2): Yelp Fusion / Google Places (documented stub) ---
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=
